/* clang-format off */
#include "@PREFIX@.h"
#include <assert.h>
#include <stddef.h>
#include <stdint.h>
/* clang-format on */
/**
 * \file strict_fibonacci_heaps.c.in
 * \brief Strict Fibonacci Heaps implementation.
 */

#define SFH_CHECK_RC(expr) do { \
    @PREFIX@_error_t _rc = (expr); \
    if (_rc != @PREFIX@_SUCCESS) return _rc; \
} while(0)

#define PASSIVE_GROUP 0
#define FREE_MULTIPLE_GROUP 1
#define FREE_SINGLE_GROUP 2
#define LOSS_ZERO_GROUP 3
#define LOSS_ONE_MULTIPLE_GROUP 4
#define LOSS_ONE_SINGLE_GROUP 5
#define LOSS_TWO_GROUP 6
#define SFH_NUM_FIX_GROUPS 7
#define SFH_MAX_REDUCTIONS 20
#define SFH_GROUP_MAX_COUNT 3
#define SFH_PASSIVE_REDUCTIONS 3
#define SFH_INSERT_REDUCTIONS 5
#define SFH_DECREASE_KEY_REDUCTIONS 10
#define SFH_MELD_REDUCTIONS 2

/**
 * \brief Internal function node_lt.
 * \param a Internal parameter.
 * \param b Internal parameter.
 * \param out_lt Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_lt(const @PREFIX@_node_t *a, const @PREFIX@_node_t *b, int *out_lt) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!a || !b || !out_lt) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a->is_min_inf) { *out_lt = 1; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (b->is_min_inf) { *out_lt = 0; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a->key < b->key) { *out_lt = 1; return @PREFIX@_SUCCESS; }
    if (a->key == b->key) {
        *out_lt = ((uintptr_t)a < (uintptr_t)b);
        return @PREFIX@_SUCCESS;
    }
    *out_lt = 0;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_active.
 * \param node Internal parameter.
 * \param out_active Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_active(const @PREFIX@_node_t *node, int *out_active) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_active) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_active = (node->rank && node->rank->heap && node->rank->heap->active); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_passive.
 * \param node Internal parameter.
 * \param out_passive Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_passive(const @PREFIX@_node_t *node, int *out_passive) {
    int active; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_passive) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_active(node, &active)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_passive = !active;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_free.
 * \param node Internal parameter.
 * \param out_free Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_free(const @PREFIX@_node_t *node, int *out_free) {
    int active; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_free) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_active(node, &active)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_free = (active && node->is_free);
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_fixed.
 * \param node Internal parameter.
 * \param out_fixed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_fixed(const @PREFIX@_node_t *node, int *out_fixed) {
    int active; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_fixed) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_active(node, &active)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_fixed = (active && !node->is_free);
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_heap.
 * \param node Internal parameter.
 * \param out_heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_heap(const @PREFIX@_node_t *node, @PREFIX@_heap_t **out_heap) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_heap) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_heap = node->rank->heap;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_unlink.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_splice(@PREFIX@_node_t *h1, @PREFIX@_node_t *h2) {
    @PREFIX@_node_t *t1;
    @PREFIX@_node_t *t2;
    if (!h1 || !h2) return @PREFIX@_SUCCESS;
    t1 = h1->prev;
    t2 = h2->prev;
    h1->prev = t2;
    t1->next = h2;
    h2->prev = t1;
    t2->next = h1;
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_unlink(@PREFIX@_node_t *node) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->prev->next = node->next;
    node->next->prev = node->prev;
    node->prev = node;
    node->next = node;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert_before.
 * \param node Internal parameter.
 * \param succ Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert_before(@PREFIX@_node_t *node, @PREFIX@_node_t *succ) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (succ != NULL) {
        node->next = succ;
        node->prev = succ->prev;
        node->next->prev = node;
        node->prev->next = node;
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert_after.
 * \param node Internal parameter.
 * \param prev Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert_after(@PREFIX@_node_t *node, @PREFIX@_node_t *prev) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !prev) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->prev = prev;
    node->next = prev->next;
    node->next->prev = node;
    node->prev->next = node;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_same_group.
 * \param a Internal parameter.
 * \param b Internal parameter.
 * \param out_same Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_same_group(@PREFIX@_node_t *a, @PREFIX@_node_t *b, int *out_same) {
    int a_free, b_free, a_fixed, b_fixed;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!a || !b || !out_same) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_free(a, &a_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_free(b, &b_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a_free && b_free && a->rank == b->rank) {
        *out_same = 1;
        return @PREFIX@_SUCCESS;
    }
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(a, &a_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(b, &b_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a_fixed && b_fixed && a->rank == b->rank && a->loss == 1 && b->loss == 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        *out_same = 1;
        return @PREFIX@_SUCCESS;
    }

    *out_same = 0;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_head.
 * \param heap Internal parameter.
 * \param out_head Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_head(@PREFIX@_heap_t *heap, @PREFIX@_node_t **out_head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !out_head) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (heap->fix_passive) { *out_head = heap->fix_passive; return @PREFIX@_SUCCESS; }
    if (heap->fix_free_multiple) { *out_head = heap->fix_free_multiple; return @PREFIX@_SUCCESS; }
    if (heap->fix_free_single) { *out_head = heap->fix_free_single; return @PREFIX@_SUCCESS; }
    if (heap->fix_loss_zero) { *out_head = heap->fix_loss_zero; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (heap->fix_loss_one_multiple) { *out_head = heap->fix_loss_one_multiple; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (heap->fix_loss_one_single) { *out_head = heap->fix_loss_one_single; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (heap->fix_loss_two) { *out_head = heap->fix_loss_two; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    *out_head = NULL;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insertion_point.
 * \param heap Internal parameter.
 * \param group Internal parameter.
 * \param out_node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insertion_point(@PREFIX@_heap_t *heap, int group, @PREFIX@_node_t **out_node) {
    @PREFIX@_node_t* points[SFH_NUM_FIX_GROUPS];
    int i;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !out_node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    points[0] = heap->fix_passive;
    points[1] = heap->fix_free_multiple;
    points[2] = heap->fix_free_single;
    points[3] = heap->fix_loss_zero;
    points[4] = heap->fix_loss_one_multiple;
    points[5] = heap->fix_loss_one_single;
    points[6] = heap->fix_loss_two;

    for (i = 0; i < SFH_NUM_FIX_GROUPS; ++i) {
        int idx = (group + i) % SFH_NUM_FIX_GROUPS;
        if (points[idx]) {
            *out_node = points[idx];
            return @PREFIX@_SUCCESS;
        }
    }

    *out_node = NULL;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert.
 * \param heap Internal parameter.
 * \param group Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert(@PREFIX@_heap_t *heap, int group, @PREFIX@_node_t *node) {
    @PREFIX@_node_t *succ;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(fix_list_insertion_point(heap, group, &succ)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(fix_list_insert_before(node, succ)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (group == FREE_MULTIPLE_GROUP) heap->fix_free_multiple = node;
    else if (group == FREE_SINGLE_GROUP) heap->fix_free_single = node;
    else if (group == LOSS_ZERO_GROUP) heap->fix_loss_zero = node;
    else if (group == LOSS_ONE_MULTIPLE_GROUP) heap->fix_loss_one_multiple = node;
    else if (group == LOSS_ONE_SINGLE_GROUP) heap->fix_loss_one_single = node; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    else if (group == LOSS_TWO_GROUP) heap->fix_loss_two = node; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_group.
 * \param node Internal parameter.
 * \param head Internal parameter.
 * \param count Internal parameter.
 * \param first Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_group(@PREFIX@_node_t *node, @PREFIX@_node_t *head, int *count, @PREFIX@_node_t **first) {
    @PREFIX@_node_t *last;
    int same;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !count || !first) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    last = node;
    *count = 1;
    *first = node;

    while (*count < SFH_GROUP_MAX_COUNT && *first != head) {
        SFH_CHECK_RC(fix_list_same_group(node, (*first)->prev, &same)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (!same) break;
        *first = (*first)->prev;
        (*count)++;
    }

    while (*count < SFH_GROUP_MAX_COUNT && last->next != head) {
        SFH_CHECK_RC(fix_list_same_group(node, last->next, &same)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (!same) break;
        last = last->next;
        (*count)++;
    }

    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_retire.
 * \param heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_retire(@PREFIX@_heap_t *heap) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    heap->fix_passive = NULL;
    heap->fix_free_multiple = NULL;
    heap->fix_free_single = NULL;
    heap->fix_loss_zero = NULL;
    heap->fix_loss_one_multiple = NULL;
    heap->fix_loss_one_single = NULL;
    heap->fix_loss_two = NULL;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_add.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */

static @PREFIX@_error_t fix_list_add_free(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head) {
    @PREFIX@_node_t *first = node->rank->free_node;
    if (first == NULL) {
        node->rank->free_node = node;
        SFH_CHECK_RC(fix_list_insert(heap, FREE_SINGLE_GROUP, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    } else {
        int count;
        @PREFIX@_node_t *f;
        SFH_CHECK_RC(fix_list_group(first, head, &count, &f)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        if (count >= 2) {
            SFH_CHECK_RC(fix_list_insert_after(node, first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        } else {
            if (heap->fix_free_single == first) {
                int next_is_free = 0;
                if (first->next != head) {
                    SFH_CHECK_RC(node_is_free(first->next, &next_is_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                }
                if (next_is_free) {
                    heap->fix_free_single = first->next;
                } else {
                    heap->fix_free_single = NULL;
                }
            } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(fix_list_unlink(first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(fix_list_insert(heap, FREE_MULTIPLE_GROUP, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(fix_list_insert(heap, FREE_MULTIPLE_GROUP, first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            node->rank->free_node = first;
        }
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add_fixed_loss_zero(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    SFH_CHECK_RC(fix_list_insert(heap, LOSS_ZERO_GROUP, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add_fixed_loss_two(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    SFH_CHECK_RC(fix_list_insert(heap, LOSS_TWO_GROUP, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add_fixed_loss_one(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head) {
    @PREFIX@_node_t *first = node->rank->loss_one_node;
    if (first == NULL) {
        node->rank->loss_one_node = node;
        SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_SINGLE_GROUP, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    } else {
        int count;
        @PREFIX@_node_t *f;
        SFH_CHECK_RC(fix_list_group(first, head, &count, &f)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        if (count >= 2) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            SFH_CHECK_RC(fix_list_insert_after(node, first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        } else {
            if (heap->fix_loss_one_single == first) {
                int next_is_fixed = 0;
                if (first->next != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    SFH_CHECK_RC(node_is_fixed(first->next, &next_is_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                }
                if (next_is_fixed && first->next->loss == 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    heap->fix_loss_one_single = first->next;
                } else {
                    /* LCOV_EXCL_START */
                    heap->fix_loss_one_single = NULL; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    /* LCOV_EXCL_STOP */
                }
            } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(fix_list_unlink(first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_MULTIPLE_GROUP, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_MULTIPLE_GROUP, first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_node_t *head;
    int is_free;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(fix_list_head(heap, &head)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_is_free(node, &is_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        if (is_free) {
        SFH_CHECK_RC(fix_list_add_free(heap, node, head));
    } else {
        if (node->loss == 0) {
            SFH_CHECK_RC(fix_list_add_fixed_loss_zero(heap, node));
        } else if (node->loss >= 2) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            SFH_CHECK_RC(fix_list_add_fixed_loss_two(heap, node));
        } else {
            SFH_CHECK_RC(fix_list_add_fixed_loss_one(heap, node, head));
        }
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_remove.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */

static @PREFIX@_error_t fix_list_remove_passive(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head, @PREFIX@_node_t *succ) {
    if (heap->fix_passive == node) {
        int succ_is_passive = 0;
        if (succ != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(node_is_passive(succ, &succ_is_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
        if (succ_is_passive) heap->fix_passive = succ;
        else heap->fix_passive = NULL;
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_free(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head, @PREFIX@_node_t *succ) {
    int count;
    @PREFIX@_node_t *first; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_group(node, head, &count, &first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (count == 1) {
        if (heap->fix_free_single == node) {
            int succ_is_free = 0;
            if (succ != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                SFH_CHECK_RC(node_is_free(succ, &succ_is_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            }
            if (succ_is_free) heap->fix_free_single = succ;
            else heap->fix_free_single = NULL;
        }
    } else if (count >= SFH_GROUP_MAX_COUNT) {
        if (heap->fix_free_multiple == node) heap->fix_free_multiple = succ;
    } else {
        @PREFIX@_node_t *other = (first != node) ? first : succ;
        if (heap->fix_free_multiple == first) {
            int f_free = 0, fn_free = 0;
            first = first->next->next; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (first != head) { SFH_CHECK_RC(node_is_free(first, &f_free)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (first->next != head) { SFH_CHECK_RC(node_is_free(first->next, &fn_free)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (f_free && fn_free && first->rank == first->next->rank) {
                heap->fix_free_multiple = first;
            } else {
                heap->fix_free_multiple = NULL;
            }
        } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_unlink(other)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_insert(heap, FREE_SINGLE_GROUP, other)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_loss_zero(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head, @PREFIX@_node_t *succ) {
    if (heap->fix_loss_zero == node) {
        int succ_is_fixed = 0; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (succ != head) { SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (succ_is_fixed && succ->loss == 0) heap->fix_loss_zero = succ; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        else heap->fix_loss_zero = NULL;
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_loss_two(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head, @PREFIX@_node_t *succ) {
    if (heap->fix_loss_two == node) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        int succ_is_fixed = 0; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (succ != head) { SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (succ_is_fixed && succ->loss >= 2) heap->fix_loss_two = succ; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        else heap->fix_loss_two = NULL; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_loss_one(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_node_t *head, @PREFIX@_node_t *succ) {
    int count;
    @PREFIX@_node_t *first; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_group(node, head, &count, &first)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (count == 1) {
        if (heap->fix_loss_one_single == node) {
            int succ_is_fixed = 0; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (succ != head) { SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (succ_is_fixed && succ->loss == 1) heap->fix_loss_one_single = succ; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            else heap->fix_loss_one_single = NULL;
        }
    } else if (count >= SFH_GROUP_MAX_COUNT) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        if (heap->fix_loss_one_multiple == node) heap->fix_loss_one_multiple = succ; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    } else {
        @PREFIX@_node_t *other = (first != node) ? first : succ;
        if (heap->fix_loss_one_multiple == first) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            int f_fixed = 0, fn_fixed = 0;
            first = first->next->next; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (first != head) { SFH_CHECK_RC(node_is_fixed(first, &f_fixed)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (first->next != head) { SFH_CHECK_RC(node_is_fixed(first->next, &fn_fixed)); } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (f_fixed && first->loss == 1 && fn_fixed && first->next->loss == 1 && first->rank == first->next->rank) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                heap->fix_loss_one_multiple = first; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            } else {
                heap->fix_loss_one_multiple = NULL;
            }
        } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_unlink(other)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_SINGLE_GROUP, other)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_node_t *succ;
    @PREFIX@_node_t *head;
    int is_active, is_passive, is_free;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    succ = node->next; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_head(heap, &head)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_active(node, &is_active)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (is_active && node->rank->free_node == node) {
        int succ_is_free = 0;
        if (succ != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(node_is_free(succ, &succ_is_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
        if (succ_is_free && succ->rank == node->rank) {
            node->rank->free_node = succ;
        } else {
            node->rank->free_node = NULL;
        }
    }

    if (is_active && node->rank->loss_one_node == node) {
        int succ_is_fixed = 0;
        if (succ != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
        if (succ_is_fixed && succ->loss == 1 && succ->rank == node->rank) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            node->rank->loss_one_node = succ;
        } else {
            node->rank->loss_one_node = NULL;
        }
    }

    if (heap->size == 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_retire(heap)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    } else { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_is_passive(node, &is_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_is_free(node, &is_free)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        if (is_passive) {
            SFH_CHECK_RC(fix_list_remove_passive(heap, node, head, succ));
        } else if (is_free) {
            SFH_CHECK_RC(fix_list_remove_free(heap, node, head, succ));
        } else {
            if (node->loss == 0) {
                SFH_CHECK_RC(fix_list_remove_loss_zero(heap, node, head, succ));
            } else if (node->loss >= 2) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
                SFH_CHECK_RC(fix_list_remove_loss_two(heap, node, head, succ));
            } else {
                SFH_CHECK_RC(fix_list_remove_loss_one(heap, node, head, succ));
            }
        }
        SFH_CHECK_RC(fix_list_unlink(node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function get_rank_obj.
 * \param heap Internal parameter.
 * \param r Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t get_rank_obj(@PREFIX@_heap_t *heap, int r, @PREFIX@_rank_t **out_rank) {
    @PREFIX@_rank_t *rank;
    if (r >= SFH_MAX_RANKS) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_START */
        return @PREFIX@_ERR_OUT_OF_RANKS; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_STOP */
    }
    rank = &heap->rank_pool[r];
    if (rank->heap == NULL) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rank->heap = heap;
        rank->rank = r;
        rank->free_node = NULL;
        rank->loss_one_node = NULL;
        rank->reference_count = 0;
        rank->next = NULL;
        rank->prev = NULL;
    }
    *out_rank = rank;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_decrease_reference_count.
 * \param rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_decrease_reference_count(@PREFIX@_rank_t *rank) {
    @PREFIX@_heap_t *heap; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!rank) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    heap = rank->heap;
    rank->reference_count--;
    if (rank->reference_count == 0) {
        if (heap->rank_list == rank) {
            heap->rank_list = rank->next;
        }
        if (rank->next) rank->next->prev = rank->prev; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        if (rank->prev) rank->prev->next = rank->next;
        rank->next = NULL;
        rank->prev = NULL;
        rank->heap = NULL;
        rank->free_node = NULL;
        rank->loss_one_node = NULL;
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_increase_reference_count.
 * \param rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_increase_reference_count(@PREFIX@_rank_t *rank) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!rank) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rank->reference_count++;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_next.
 * \param rank Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_next(@PREFIX@_rank_t *rank, @PREFIX@_rank_t **out_rank) {
    if (rank->next == NULL || rank->next->rank > rank->rank + 1) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        @PREFIX@_rank_t *new_rank;
        SFH_CHECK_RC(get_rank_obj(rank->heap, rank->rank + 1, &new_rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        new_rank->prev = rank;
        new_rank->next = rank->next;
        rank->next = new_rank;
        if (new_rank->next) new_rank->next->prev = new_rank; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    }
    *out_rank = rank->next;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_prev.
 * \param rank Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_prev(@PREFIX@_rank_t *rank, @PREFIX@_rank_t **out_rank) {
    if (rank->prev == NULL || rank->prev->rank < rank->rank - 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_START */
        @PREFIX@_rank_t *new_rank;
        SFH_CHECK_RC(get_rank_obj(rank->heap, rank->rank - 1, &new_rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        new_rank->prev = rank->prev; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        new_rank->next = rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (new_rank->prev) new_rank->prev->next = new_rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        else rank->heap->rank_list = new_rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rank->prev = new_rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_STOP */
    }
    *out_rank = rank->prev;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_rank_zero.
 * \param heap Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_rank_zero(@PREFIX@_heap_t *heap, @PREFIX@_rank_t **out_rank) {
    @PREFIX@_rank_t *rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !out_rank) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rank = heap->rank_list;
    if (rank == NULL) {
        SFH_CHECK_RC(get_rank_obj(heap, 0, &rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        heap->rank_list = rank;
    }
    SFH_CHECK_RC(rank_increase_reference_count(rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_rank = rank;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_change_rank.
 * \param node Internal parameter.
 * \param new_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_adjust_loss(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, int delta) {
    SFH_CHECK_RC(fix_list_remove(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->loss += delta;
    SFH_CHECK_RC(fix_list_add(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t node_change_rank(@PREFIX@_node_t *node, @PREFIX@_rank_t *new_rank) {
    @PREFIX@_heap_t *heap; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_heap(node, &heap)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(rank_increase_reference_count(new_rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_remove(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(rank_decrease_reference_count(node->rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->rank = new_rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_add(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_increase_rank.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_increase_rank(@PREFIX@_node_t *node) {
    @PREFIX@_rank_t *next_rank;
    SFH_CHECK_RC(rank_next(node->rank, &next_rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return node_change_rank(node, next_rank);
}

/**
 * \brief Internal function node_decrease_rank.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_decrease_rank(@PREFIX@_node_t *node) {
    @PREFIX@_rank_t *prev_rank;
    SFH_CHECK_RC(rank_prev(node->rank, &prev_rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return node_change_rank(node, prev_rank);
}

/**
 * \brief Internal function node_add_child.
 * \param parent Internal parameter.
 * \param child Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_add_child(@PREFIX@_node_t *parent, @PREFIX@_node_t *child) {
    int child_is_passive, parent_is_active, child_is_fixed;

    child->parent = parent;
    if (parent->left_child == NULL) {
        parent->left_child = child;
    } else {
        child->right = parent->left_child;
        child->left = child->right->left;
        child->right->left = child;
        child->left->right = child;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_is_passive(child, &child_is_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (!child_is_passive) {
            parent->left_child = child;
        }
    }
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_active(parent, &parent_is_active)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(child, &child_is_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (parent_is_active && child_is_fixed) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        SFH_CHECK_RC(node_increase_rank(parent)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t node_unlink_from_parent(@PREFIX@_node_t *node) {
    @PREFIX@_node_t *parent = node->parent;
    @PREFIX@_node_t *right = node->right;
    @PREFIX@_node_t *left = node->left;

    node->parent = NULL;
    if (parent != NULL && parent->left_child == node) {
        if (right != node) parent->left_child = right;
        else parent->left_child = NULL;
    }

    if (right != node) {
        left->right = right;
        right->left = left;
        node->right = node;
        node->left = node;
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_cut.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_cut(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_node_t *parent = node->parent;
    int node_fixed, parent_active, parent_fixed;

    SFH_CHECK_RC(node_unlink_from_parent(node));

 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(node, &node_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_active(parent, &parent_active)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (node_fixed && parent_active) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_decrease_rank(parent)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_is_fixed(parent, &parent_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (parent_fixed) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            SFH_CHECK_RC(node_adjust_loss(heap, parent, 1)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_free2fixed.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_set_state(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, int is_free, int loss) {
    SFH_CHECK_RC(fix_list_remove(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->is_free = is_free;
    node->loss = loss;
    SFH_CHECK_RC(fix_list_add(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t node_free2fixed(@PREFIX@_node_t *node) {
    @PREFIX@_heap_t *heap; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_heap(node, &heap)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_set_state(heap, node, 0, 0)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_fixed2free.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_fixed2free(@PREFIX@_node_t *node) {
    @PREFIX@_node_t *parent = node->parent;
    @PREFIX@_heap_t *heap;
    int parent_fixed;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_heap(node, &heap)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_set_state(heap, node, 1, -1)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_decrease_rank(parent)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(parent, &parent_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (parent_fixed) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_adjust_loss(heap, parent, 1)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_passive2free.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_passive2free(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_rank_t *rank_zero;
    @PREFIX@_node_t *parent = node->parent;

    SFH_CHECK_RC(heap_rank_zero(heap, &rank_zero)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_remove(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(rank_decrease_reference_count(node->rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->rank = rank_zero;
    node->is_free = 1;
    node->loss = -1;

    if (parent != NULL) {
        SFH_CHECK_RC(node_cut(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_add_child(parent, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_add(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_link.
 * \param heap Internal parameter.
 * \param x Internal parameter.
 * \param y Internal parameter.
 * \param out_winner Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_link(@PREFIX@_heap_t *heap, @PREFIX@_node_t *x, @PREFIX@_node_t *y, @PREFIX@_node_t **out_winner) {
    int is_lt;
    (void)heap; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_lt(x, y, &is_lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (is_lt) {
        SFH_CHECK_RC(node_add_child(x, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        *out_winner = x;
    } else {
        SFH_CHECK_RC(node_add_child(y, x)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        *out_winner = y;
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_passive.
 * \param heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_passive(@PREFIX@_heap_t *heap) {
    int i;
    for (i = 0; i < SFH_PASSIVE_REDUCTIONS; ++i) {
        if (heap->fix_passive == NULL) return @PREFIX@_SUCCESS;
        SFH_CHECK_RC(node_passive2free(heap, heap->fix_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_free.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_free(@PREFIX@_heap_t *heap, int *out_changed) {
    @PREFIX@_node_t *x = heap->fix_free_multiple;
    @PREFIX@_node_t *y, *z;
    int is_lt, z_passive;
    *out_changed = 0;
    if (x == NULL) return @PREFIX@_SUCCESS;
    y = x->next;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_lt(y, x, &is_lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (is_lt) {
        @PREFIX@_node_t *tmp = x;
        x = y;
        y = tmp;
    }

    SFH_CHECK_RC(node_cut(heap, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_free2fixed(y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_add_child(x, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    z = x->left_child->left; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_passive(z, &z_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (z_passive) {
        /* LCOV_EXCL_START */
        SFH_CHECK_RC(node_cut(heap, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_add_child(heap->root, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_STOP */
    }
    *out_changed = 1;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_root.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */


static @PREFIX@_error_t heap_reduce_root_cut_and_sort(@PREFIX@_heap_t *heap, @PREFIX@_node_t **x_ptr, @PREFIX@_node_t **y_ptr, @PREFIX@_node_t **z_ptr) {
    @PREFIX@_node_t *x = *x_ptr, *y = *y_ptr, *z = *z_ptr, *tmp;
    int lt;
    SFH_CHECK_RC(node_cut(heap, x)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_cut(heap, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_cut(heap, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_passive2free(heap, x)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_passive2free(heap, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_passive2free(heap, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_lt(y, x, &lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (lt) { tmp = x; x = y; y = tmp; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_lt(z, y, &lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (lt) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_START */
        tmp = y; y = z; z = tmp; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_lt(y, x, &lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (lt) { tmp = x; x = y; y = tmp; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_STOP */
    }

    *x_ptr = x;
    *y_ptr = y;
    *z_ptr = z;
    return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t heap_reduce_root(@PREFIX@_heap_t *heap, int *out_changed) {
    @PREFIX@_node_t *root = heap->root;
    @PREFIX@_node_t *x, *y, *z;
    int x_passive;
    *out_changed = 0;

    if (root == NULL || root->left_child == NULL) return @PREFIX@_SUCCESS; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    z = root->left_child->left;
    y = z->left;
    x = y->left;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_passive(x, &x_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (z == y || z == x || !x_passive) return @PREFIX@_SUCCESS;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(heap_reduce_root_cut_and_sort(heap, &x, &y, &z));
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_free2fixed(y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_free2fixed(z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_add_child(root, x)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_add_child(x, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_add_child(y, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    *out_changed = 1;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_loss_one.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_loss_one(@PREFIX@_heap_t *heap, int *out_changed) {
    @PREFIX@_node_t *x = heap->fix_loss_one_multiple;
    @PREFIX@_node_t *y, *z;
    int is_lt, z_passive;
    *out_changed = 0;
    if (x == NULL) return @PREFIX@_SUCCESS;
    y = x->next;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_lt(y, x, &is_lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (is_lt) {
        @PREFIX@_node_t *tmp = x;
        x = y;
        y = tmp;
    }

    SFH_CHECK_RC(node_cut(heap, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_adjust_loss(heap, x, -1)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_adjust_loss(heap, y, -1)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(node_add_child(x, y)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    z = x->left_child->left; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_passive(z, &z_passive)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (z_passive) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_START */
        SFH_CHECK_RC(node_cut(heap, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_add_child(heap->root, z)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_STOP */
    }
    *out_changed = 1;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_loss_two.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_loss_two(@PREFIX@_heap_t *heap, int *out_changed) {
    @PREFIX@_node_t *x = heap->fix_loss_two;
    *out_changed = 0;
    if (x == NULL) return @PREFIX@_SUCCESS; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    SFH_CHECK_RC(node_fixed2free(x)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_changed = 1; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    return @PREFIX@_SUCCESS; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
}

/**
 * \brief Internal function heap_reduce_loss.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_loss(@PREFIX@_heap_t *heap, int *out_changed) {
    *out_changed = 0;
    SFH_CHECK_RC(heap_reduce_loss_one(heap, out_changed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (*out_changed) return @PREFIX@_SUCCESS;

    SFH_CHECK_RC(heap_reduce_loss_two(heap, out_changed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_SUCCESS;
}

typedef @PREFIX@_error_t (*reduction_func)(@PREFIX@_heap_t *, int *);

/**
 * \brief Internal function heap_apply_reductions.
 * \param heap Internal parameter.
 * \param reductions Internal parameter.
 * \param count Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_apply_reductions(@PREFIX@_heap_t *heap, reduction_func *reductions, int count) {
    reduction_func failed[SFH_MAX_REDUCTIONS];
    int failed_count;
    int i;
    int changed;

    if (count > SFH_MAX_REDUCTIONS) count = SFH_MAX_REDUCTIONS;

    while (count > 0) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        failed_count = 0;
        for (i = 0; i < count; ++i) {
            SFH_CHECK_RC(reductions[i](heap, &changed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (!changed) {
                failed[failed_count++] = reductions[i];
            }
        }
        if (failed_count == count) return @PREFIX@_SUCCESS;
        for (i = 0; i < failed_count; ++i) {
            reductions[i] = failed[i];
        }
        count = failed_count;
    }
    /* LCOV_EXCL_START */
    return @PREFIX@_SUCCESS; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    /* LCOV_EXCL_STOP */
}


@PREFIX@_error_t @PREFIX@_init(@PREFIX@_heap_t *heap) {
    int i;
    if (!heap) return @PREFIX@_ERR_NULL_ARG;

    heap->active = 1;
    heap->size = 0;
    heap->root = NULL;
    heap->rank_list = NULL;

    heap->fix_passive = NULL;
    heap->fix_free_multiple = NULL;
    heap->fix_free_single = NULL;
    heap->fix_loss_zero = NULL;
    heap->fix_loss_one_multiple = NULL;
    heap->fix_loss_one_single = NULL;
    heap->fix_loss_two = NULL;

    for (i = 0; i < SFH_MAX_RANKS; ++i) {
        heap->rank_pool[i].heap = NULL;
    }

    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_empty(const @PREFIX@_heap_t *heap, int *out_empty) {
    if (!heap || !out_empty) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    *out_empty = (heap->size == 0) ? 1 : 0; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    return @PREFIX@_SUCCESS; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
}

@PREFIX@_error_t @PREFIX@_find_min(const @PREFIX@_heap_t *heap, @PREFIX@_node_t **out_node) {
    if (!heap || !out_node) return @PREFIX@_ERR_NULL_ARG;
    if (heap->size == 0) return @PREFIX@_ERR_EMPTY;
    *out_node = heap->root;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_retire.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_retire(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_rank_t *rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rank = node->rank; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_remove(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    heap->size--;
    node->rank = NULL; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(rank_decrease_reference_count(rank)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_insert(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_key_t key, @PREFIX@_val_t value) {
    reduction_func reductions[SFH_INSERT_REDUCTIONS];
    @PREFIX@_rank_t *rank_zero;

    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG;

    SFH_CHECK_RC(heap_rank_zero(heap, &rank_zero)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    heap->size++;
    node->key = key;
    node->value = value;
    node->parent = NULL;
    node->left_child = NULL;
    node->right = node;
    node->left = node;
    node->is_free = 1;
    node->loss = -1;
    node->is_min_inf = 0;

    node->rank = rank_zero;
    node->prev = node;
    node->next = node; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(fix_list_add(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (heap->root == NULL) {
        heap->root = node;
    } else {
        @PREFIX@_node_t *new_root;
        SFH_CHECK_RC(heap_link(heap, heap->root, node, &new_root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        heap->root = new_root;

        reductions[0] = heap_reduce_free;
        reductions[1] = heap_reduce_free;
        reductions[2] = heap_reduce_free;
        reductions[3] = heap_reduce_root;
        reductions[4] = heap_reduce_root;
        SFH_CHECK_RC(heap_apply_reductions(heap, reductions, SFH_INSERT_REDUCTIONS)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    return @PREFIX@_SUCCESS;
}


@PREFIX@_error_t @PREFIX@_meld(@PREFIX@_heap_t *h1, @PREFIX@_heap_t *h2, @PREFIX@_heap_t **out_heap) {
    @PREFIX@_heap_t *small_heap, *large_heap;
    reduction_func reductions[SFH_MELD_REDUCTIONS];

    if (!h1 || !h2 || !out_heap) return @PREFIX@_ERR_NULL_ARG;

    if (h1->size < h2->size) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_START */
        small_heap = h1; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        large_heap = h2; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        /* LCOV_EXCL_STOP */
    } else {
        small_heap = h2;
        large_heap = h1;
    }

    small_heap->active = 0;
    large_heap->size += small_heap->size;

    if (small_heap->size > 0) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        @PREFIX@_node_t *small_root = small_heap->root;
        @PREFIX@_node_t *large_head;
        @PREFIX@_node_t *small_head;
        @PREFIX@_node_t *new_root;

        small_heap->size = 0;
        small_heap->root = NULL;
        small_heap->rank_list = NULL; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_retire(small_heap)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(fix_list_head(large_heap, &large_head)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        small_head = small_root;

        SFH_CHECK_RC(fix_list_splice(small_head, large_head)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        large_heap->fix_passive = small_head;

        SFH_CHECK_RC(heap_link(large_heap, large_heap->root, small_root, &new_root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        large_heap->root = new_root;

        reductions[0] = heap_reduce_free;
        reductions[1] = heap_reduce_root;
        SFH_CHECK_RC(heap_apply_reductions(large_heap, reductions, SFH_MELD_REDUCTIONS)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    *out_heap = large_heap;
    return @PREFIX@_SUCCESS;
}


static @PREFIX@_error_t heap_consolidate_roots(@PREFIX@_heap_t *heap, @PREFIX@_node_t *root) {
    @PREFIX@_node_t *new_root = root->left_child;
    @PREFIX@_node_t *child = new_root->right;
    int child_fixed, is_lt;

    while (child != root->left_child) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_lt(child, new_root, &is_lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (is_lt) {
            new_root = child;
        }
        child = child->right;
    }
/* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(new_root, &child_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (child_fixed) {
        SFH_CHECK_RC(node_fixed2free(new_root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }
    SFH_CHECK_RC(node_cut(heap, new_root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    while (root->left_child != NULL) {
        @PREFIX@_node_t *winner;
        child = root->left_child; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_is_fixed(child, &child_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (child_fixed) {
            SFH_CHECK_RC(node_fixed2free(child)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
        SFH_CHECK_RC(node_cut(heap, child)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(heap_link(heap, new_root, child, &winner)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    heap->root = new_root; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_delete_min(@PREFIX@_heap_t *heap) {
    @PREFIX@_node_t *root;

    if (!heap) return @PREFIX@_ERR_NULL_ARG;
    if (heap->size == 0) return @PREFIX@_ERR_EMPTY;

    root = heap->root;
    if (heap->size == 1) {
        heap->root = NULL; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_retire(heap, root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    } else {
        SFH_CHECK_RC(heap_consolidate_roots(heap, root));

        SFH_CHECK_RC(node_retire(heap, root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(heap_reduce_passive(heap)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        while (1) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            int changed;
            SFH_CHECK_RC(heap_reduce_loss(heap, &changed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (!changed) break; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        }

        while (1) {
            int changed1, changed2;
            SFH_CHECK_RC(heap_reduce_free(heap, &changed1)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

            SFH_CHECK_RC(heap_reduce_root(heap, &changed2)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

            if (!changed1 && !changed2) break; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
    }
    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_decrease_key(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_key_t key) {
    @PREFIX@_node_t *parent;
    @PREFIX@_node_t *new_root;
    reduction_func reductions[SFH_DECREASE_KEY_REDUCTIONS];
    int i;
    int changed;
    int is_lt = 0, node_fixed;

    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG;

    node->key = key;
    parent = node->parent;

    if (parent != NULL) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_lt(node, parent, &is_lt)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    if (parent == NULL || !is_lt) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        return @PREFIX@_SUCCESS;
    }
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    SFH_CHECK_RC(node_is_fixed(node, &node_fixed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (node_fixed) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        SFH_CHECK_RC(node_fixed2free(node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    SFH_CHECK_RC(node_cut(heap, node)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    SFH_CHECK_RC(heap_link(heap, node, heap->root, &new_root)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    heap->root = new_root;

    SFH_CHECK_RC(heap_reduce_loss(heap, &changed)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    for (i = 0; i < 6; ++i) reductions[i] = heap_reduce_free;
    for (i = 6; i < SFH_DECREASE_KEY_REDUCTIONS; ++i) reductions[i] = heap_reduce_root;

    SFH_CHECK_RC(heap_apply_reductions(heap, reductions, SFH_DECREASE_KEY_REDUCTIONS)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_delete(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG;

    node->is_min_inf = 1;
    SFH_CHECK_RC(@PREFIX@_decrease_key(heap, node, node->key)); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_delete_min(heap);
}
