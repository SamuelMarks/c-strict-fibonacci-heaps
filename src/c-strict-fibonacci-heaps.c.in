/* clang-format off */
#include "@PREFIX@.h"
#include <assert.h>
#include <stddef.h>
#include <stdint.h>
/* clang-format on */
/**
 * \file strict_fibonacci_heaps.c.in
 * \brief Strict Fibonacci Heaps implementation.
 */

#define PASSIVE_GROUP 0
#define FREE_MULTIPLE_GROUP 1
#define FREE_SINGLE_GROUP 2
#define LOSS_ZERO_GROUP 3
#define LOSS_ONE_MULTIPLE_GROUP 4
#define LOSS_ONE_SINGLE_GROUP 5
#define LOSS_TWO_GROUP 6

/**
 * \brief Internal function node_lt.
 * \param a Internal parameter.
 * \param b Internal parameter.
 * \param out_lt Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_lt(const @PREFIX@_node_t *a, const @PREFIX@_node_t *b, int *out_lt) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!a || !b || !out_lt) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a->is_min_inf) { *out_lt = 1; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (b->is_min_inf) { *out_lt = 0; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a->key < b->key) { *out_lt = 1; return @PREFIX@_SUCCESS; }
    if (a->key == b->key) {
        *out_lt = ((uintptr_t)a < (uintptr_t)b);
        return @PREFIX@_SUCCESS;
    }
    *out_lt = 0;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_active.
 * \param node Internal parameter.
 * \param out_active Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_active(const @PREFIX@_node_t *node, int *out_active) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_active) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_active = (node->rank && node->rank->heap && node->rank->heap->active); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_passive.
 * \param node Internal parameter.
 * \param out_passive Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_passive(const @PREFIX@_node_t *node, int *out_passive) {
    @PREFIX@_error_t rc;
    int active; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_passive) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_active(node, &active); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_passive = !active;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_free.
 * \param node Internal parameter.
 * \param out_free Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_free(const @PREFIX@_node_t *node, int *out_free) {
    @PREFIX@_error_t rc;
    int active; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_free) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_active(node, &active); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_free = (active && node->is_free);
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_fixed.
 * \param node Internal parameter.
 * \param out_fixed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_fixed(const @PREFIX@_node_t *node, int *out_fixed) {
    @PREFIX@_error_t rc;
    int active; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_fixed) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_active(node, &active); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_fixed = (active && !node->is_free);
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_heap.
 * \param node Internal parameter.
 * \param out_heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_heap(const @PREFIX@_node_t *node, @PREFIX@_heap_t **out_heap) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !out_heap) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    *out_heap = node->rank->heap;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_unlink.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_unlink(@PREFIX@_node_t *node) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->prev->next = node->next;
    node->next->prev = node->prev;
    node->prev = node;
    node->next = node;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert_before.
 * \param node Internal parameter.
 * \param succ Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert_before(@PREFIX@_node_t *node, @PREFIX@_node_t *succ) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (succ != NULL) {
        node->next = succ;
        node->prev = succ->prev;
        node->next->prev = node;
        node->prev->next = node;
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert_after.
 * \param node Internal parameter.
 * \param prev Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert_after(@PREFIX@_node_t *node, @PREFIX@_node_t *prev) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !prev) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    node->prev = prev;
    node->next = prev->next;
    node->next->prev = node;
    node->prev->next = node;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_same_group.
 * \param a Internal parameter.
 * \param b Internal parameter.
 * \param out_same Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_same_group(@PREFIX@_node_t *a, @PREFIX@_node_t *b, int *out_same) {
    @PREFIX@_error_t rc;
    int a_free, b_free, a_fixed, b_fixed;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!a || !b || !out_same) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_free(a, &a_free); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_free(b, &b_free); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a_free && b_free && a->rank == b->rank) {
        *out_same = 1;
        return @PREFIX@_SUCCESS;
    }
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_fixed(a, &a_fixed); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_fixed(b, &b_fixed); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (a_fixed && b_fixed && a->rank == b->rank && a->loss == 1 && b->loss == 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        *out_same = 1;
        return @PREFIX@_SUCCESS;
    }

    *out_same = 0;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_head.
 * \param heap Internal parameter.
 * \param out_head Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_head(@PREFIX@_heap_t *heap, @PREFIX@_node_t **out_head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !out_head) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (heap->fix_passive) { *out_head = heap->fix_passive; return @PREFIX@_SUCCESS; }
    if (heap->fix_free_multiple) { *out_head = heap->fix_free_multiple; return @PREFIX@_SUCCESS; }
    if (heap->fix_free_single) { *out_head = heap->fix_free_single; return @PREFIX@_SUCCESS; }
    if (heap->fix_loss_zero) { *out_head = heap->fix_loss_zero; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (heap->fix_loss_one_multiple) { *out_head = heap->fix_loss_one_multiple; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (heap->fix_loss_one_single) { *out_head = heap->fix_loss_one_single; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (heap->fix_loss_two) { *out_head = heap->fix_loss_two; return @PREFIX@_SUCCESS; } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    *out_head = NULL;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insertion_point.
 * \param heap Internal parameter.
 * \param group Internal parameter.
 * \param out_node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insertion_point(@PREFIX@_heap_t *heap, int group, @PREFIX@_node_t **out_node) {
    @PREFIX@_node_t* points[7];
    int i;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !out_node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    points[0] = heap->fix_passive;
    points[1] = heap->fix_free_multiple;
    points[2] = heap->fix_free_single;
    points[3] = heap->fix_loss_zero;
    points[4] = heap->fix_loss_one_multiple;
    points[5] = heap->fix_loss_one_single;
    points[6] = heap->fix_loss_two;

    for (i = 0; i < 7; ++i) {
        int idx = (group + i) % 7;
        if (points[idx]) {
            *out_node = points[idx];
            return @PREFIX@_SUCCESS;
        }
    }

    *out_node = NULL;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert.
 * \param heap Internal parameter.
 * \param group Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert(@PREFIX@_heap_t *heap, int group, @PREFIX@_node_t *node) {
    @PREFIX@_error_t rc;
    @PREFIX@_node_t *succ;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    rc = fix_list_insertion_point(heap, group, &succ); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    rc = fix_list_insert_before(node, succ); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (group == FREE_MULTIPLE_GROUP) heap->fix_free_multiple = node;
    else if (group == FREE_SINGLE_GROUP) heap->fix_free_single = node;
    else if (group == LOSS_ZERO_GROUP) heap->fix_loss_zero = node;
    else if (group == LOSS_ONE_MULTIPLE_GROUP) heap->fix_loss_one_multiple = node;
    else if (group == LOSS_ONE_SINGLE_GROUP) heap->fix_loss_one_single = node; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
    else if (group == LOSS_TWO_GROUP) heap->fix_loss_two = node; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_group.
 * \param node Internal parameter.
 * \param head Internal parameter.
 * \param count Internal parameter.
 * \param first Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_group(@PREFIX@_node_t *node, @PREFIX@_node_t *head, int *count, @PREFIX@_node_t **first) {
    @PREFIX@_error_t rc;
    @PREFIX@_node_t *last;
    int same;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!node || !count || !first) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    last = node;
    *count = 1;
    *first = node;

    while (*count < 3 && *first != head) {
        rc = fix_list_same_group(node, (*first)->prev, &same); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (!same) break;
        *first = (*first)->prev;
        (*count)++;
    }

    while (*count < 3 && last->next != head) {
        rc = fix_list_same_group(node, last->next, &same); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (!same) break;
        last = last->next;
        (*count)++;
    }

    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_retire.
 * \param heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_retire(@PREFIX@_heap_t *heap) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    heap->fix_passive = NULL;
    heap->fix_free_multiple = NULL;
    heap->fix_free_single = NULL;
    heap->fix_loss_zero = NULL;
    heap->fix_loss_one_multiple = NULL;
    heap->fix_loss_one_single = NULL;
    heap->fix_loss_two = NULL;
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_add.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_add(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_error_t rc;
    @PREFIX@_node_t *head;
    int is_free;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    rc = fix_list_head(heap, &head); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    rc = node_is_free(node, &is_free); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (is_free) {
        @PREFIX@_node_t *first = node->rank->free_node;
        if (first == NULL) {
            node->rank->free_node = node;
            rc = fix_list_insert(heap, FREE_SINGLE_GROUP, node); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        } else {
            int count;
            @PREFIX@_node_t *f;
            rc = fix_list_group(first, head, &count, &f); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

            if (count >= 2) {
                rc = fix_list_insert_after(node, first); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            } else {
                if (heap->fix_free_single == first) {
                    int next_is_free = 0;
                    if (first->next != head) {
                        rc = node_is_free(first->next, &next_is_free); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                        if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    }
                    if (next_is_free) {
                        heap->fix_free_single = first->next;
                    } else {
                        heap->fix_free_single = NULL;
                    }
                } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                rc = fix_list_unlink(first); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                rc = fix_list_insert(heap, FREE_MULTIPLE_GROUP, node); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                rc = fix_list_insert(heap, FREE_MULTIPLE_GROUP, first); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                node->rank->free_node = first;
            }
        }
    } else {
        if (node->loss == 0) {
            rc = fix_list_insert(heap, LOSS_ZERO_GROUP, node); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        } else if (node->loss >= 2) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            rc = fix_list_insert(heap, LOSS_TWO_GROUP, node); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        } else {
            @PREFIX@_node_t *first = node->rank->loss_one_node;
            if (first == NULL) {
                node->rank->loss_one_node = node;
                rc = fix_list_insert(heap, LOSS_ONE_SINGLE_GROUP, node); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            } else {
                int count;
                @PREFIX@_node_t *f;
                rc = fix_list_group(first, head, &count, &f); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

                if (count >= 2) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
                    rc = fix_list_insert_after(node, first); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                } else {
                    if (heap->fix_loss_one_single == first) {
                        int next_is_fixed = 0;
                        if (first->next != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                            rc = node_is_fixed(first->next, &next_is_fixed); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                        }
                        if (next_is_fixed && first->next->loss == 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                            heap->fix_loss_one_single = first->next;
                        } else {
                            /* LCOV_EXCL_START */
                            heap->fix_loss_one_single = NULL; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                            /* LCOV_EXCL_STOP */
                        }
                    } /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    rc = fix_list_unlink(first); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    rc = fix_list_insert(heap, LOSS_ONE_MULTIPLE_GROUP, node); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                    rc = fix_list_insert(heap, LOSS_ONE_MULTIPLE_GROUP, first); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
                }
            }
        }
    }
    return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_remove.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_remove(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_error_t rc;
    @PREFIX@_node_t *succ;
    @PREFIX@_node_t *head;
    int is_active, is_passive, is_free;
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    succ = node->next; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = fix_list_head(heap, &head); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_active(node, &is_active); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    if (is_active && node->rank->free_node == node) {
        int succ_is_free = 0;
        if (succ != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            rc = node_is_free(succ, &succ_is_free); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
        if (succ_is_free && succ->rank == node->rank) {
            node->rank->free_node = succ;
        } else {
            node->rank->free_node = NULL;
        }
    }

    if (is_active && node->rank->loss_one_node == node) {
        int succ_is_fixed = 0;
        if (succ != head) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            rc = node_is_fixed(succ, &succ_is_fixed); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
        if (succ_is_fixed && succ->loss == 1 && succ->rank == node->rank) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
            node->rank->loss_one_node = succ;
        } else {
            node->rank->loss_one_node = NULL;
        }
    }

    if (heap->size == 1) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rc = fix_list_retire(heap); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    } else { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rc = node_is_passive(node, &is_passive); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rc = node_is_free(node, &is_free); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

        if (is_passive) {
            if (heap->fix_passive == node) {
