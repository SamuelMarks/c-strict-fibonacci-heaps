/* clang-format off */
#include "@PREFIX@.h"
#include <assert.h>
#include <stddef.h>
#include <stdio.h>
/* clang-format on */
/**
 * \file strict_fibonacci_heaps.c.in
 * \brief Strict Fibonacci Heaps implementation.
 */

#define SFH_CHECK_RC(expr)                                                     \
  do {                                                                         \
    @PREFIX@_error_t _rc = (expr);                                            \
    if (_rc != @PREFIX@_SUCCESS) {                                            \
      fprintf(stderr, "Error %d returned from %s\n", (int)_rc, #expr); return _rc; }                                                             \
  } while (0)

#define PASSIVE_GROUP 0
#define FREE_MULTIPLE_GROUP 1
#define FREE_SINGLE_GROUP 2
#define LOSS_ZERO_GROUP 3
#define LOSS_ONE_MULTIPLE_GROUP 4
#define LOSS_ONE_SINGLE_GROUP 5
#define LOSS_TWO_GROUP 6
#define SFH_NUM_FIX_GROUPS 7
#define SFH_MAX_REDUCTIONS 20
#define SFH_GROUP_MAX_COUNT 3
#define SFH_PASSIVE_REDUCTIONS 3
#define SFH_INSERT_REDUCTIONS 5
#define SFH_DECREASE_KEY_REDUCTIONS 10
#define SFH_MELD_REDUCTIONS 2

/**
 * \brief Internal function node_lt.
 * \param a Internal parameter.
 * \param b Internal parameter.
 * \param out_lt Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_lt(const @PREFIX@_node_t *a,
                                 const @PREFIX@_node_t *b, int *out_lt) {
  if (!a || !b || !out_lt)
    return @PREFIX@_ERR_NULL_ARG;
  if (a->is_min_inf) {
    *out_lt = 1;
    return @PREFIX@_SUCCESS;
  }
  if (b->is_min_inf) {
    *out_lt = 0;
    return @PREFIX@_SUCCESS;
  }
  if (a->key < b->key) {
    *out_lt = 1;
    return @PREFIX@_SUCCESS;
  }
  if (a->key == b->key) {
    *out_lt = ((uintptr_t)a < (uintptr_t)b);
    return @PREFIX@_SUCCESS;
  }
  *out_lt = 0;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_active.
 * \param node Internal parameter.
 * \param out_active Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_active(const @PREFIX@_node_t *node,
                                        int *out_active) {
  if (!node || !out_active)
    return @PREFIX@_ERR_NULL_ARG;
  *out_active = (node->rank && node->rank->heap && node->rank->heap->active);
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_passive.
 * \param node Internal parameter.
 * \param out_passive Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_passive(const @PREFIX@_node_t *node,
                                         int *out_passive) {
  int active;
  if (!node || !out_passive)
    return @PREFIX@_ERR_NULL_ARG;
  SFH_CHECK_RC(node_is_active(node, &active));
  *out_passive = !active;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_free.
 * \param node Internal parameter.
 * \param out_free Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_free(const @PREFIX@_node_t *node,
                                      int *out_free) {
  int active;
  if (!node || !out_free)
    return @PREFIX@_ERR_NULL_ARG;
  SFH_CHECK_RC(node_is_active(node, &active));
  *out_free = (active && node->is_free);
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_is_fixed.
 * \param node Internal parameter.
 * \param out_fixed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_is_fixed(const @PREFIX@_node_t *node,
                                       int *out_fixed) {
  int active;
  if (!node || !out_fixed)
    return @PREFIX@_ERR_NULL_ARG;
  SFH_CHECK_RC(node_is_active(node, &active));
  *out_fixed = (active && !node->is_free);
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_heap.
 * \param node Internal parameter.
 * \param out_heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_heap(const @PREFIX@_node_t *node,
                                   @PREFIX@_heap_t **out_heap) {
  if (!node || !out_heap)
    return @PREFIX@_ERR_NULL_ARG;
  *out_heap = node->rank->heap;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_unlink.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_splice(@PREFIX@_node_t *h1,
                                         @PREFIX@_node_t *h2) {
  @PREFIX@_node_t *t1;
  @PREFIX@_node_t *t2;
  if (!h1 || !h2)
    return @PREFIX@_SUCCESS;
  t1 = h1->prev;
  t2 = h2->prev;
  h1->prev = t2;
  t1->next = h2;
  h2->prev = t1;
  t2->next = h1;
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_unlink(@PREFIX@_node_t *node) {
  if (!node)
    return @PREFIX@_ERR_NULL_ARG;
  node->prev->next = node->next;
  node->next->prev = node->prev;
  node->prev = node;
  node->next = node;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert_before.
 * \param node Internal parameter.
 * \param succ Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert_before(@PREFIX@_node_t *node,
                                                @PREFIX@_node_t *succ) {
  if (!node)
    return @PREFIX@_ERR_NULL_ARG;
  if (succ != NULL) {
    node->next = succ;
    node->prev = succ->prev;
    node->next->prev = node;
    node->prev->next = node;
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert_after.
 * \param node Internal parameter.
 * \param prev Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert_after(@PREFIX@_node_t *node,
                                               @PREFIX@_node_t *prev) {
  if (!node || !prev)
    return @PREFIX@_ERR_NULL_ARG;
  node->prev = prev;
  node->next = prev->next;
  node->next->prev = node;
  node->prev->next = node;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_same_group.
 * \param a Internal parameter.
 * \param b Internal parameter.
 * \param out_same Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t
fix_list_same_group(@PREFIX@_node_t *a, @PREFIX@_node_t *b, int *out_same) {
  int a_free, b_free, a_fixed, b_fixed;

  if (!a || !b || !out_same)
    return @PREFIX@_ERR_NULL_ARG;

  SFH_CHECK_RC(node_is_free(a, &a_free));
  SFH_CHECK_RC(node_is_free(b, &b_free));
  if (a_free && b_free && a->rank == b->rank) {
    *out_same = 1;
    return @PREFIX@_SUCCESS;
  }

  SFH_CHECK_RC(node_is_fixed(a, &a_fixed));
  SFH_CHECK_RC(node_is_fixed(b, &b_fixed));
  if (a_fixed && b_fixed && a->rank == b->rank && a->loss == 1 &&
      b->loss == 1) {
    *out_same = 1;
    return @PREFIX@_SUCCESS;
  }

  *out_same = 0;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_head.
 * \param heap Internal parameter.
 * \param out_head Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_head(@PREFIX@_heap_t *heap,
                                       @PREFIX@_node_t **out_head) {
  if (!heap || !out_head)
    return @PREFIX@_ERR_NULL_ARG;

  if (heap->fix_passive) {
    *out_head = heap->fix_passive;
    return @PREFIX@_SUCCESS;
  }
  if (heap->fix_free_multiple) {
    *out_head = heap->fix_free_multiple;
    return @PREFIX@_SUCCESS;
  }
  if (heap->fix_free_single) {
    *out_head = heap->fix_free_single;
    return @PREFIX@_SUCCESS;
  }
  if (heap->fix_loss_zero) {
    *out_head = heap->fix_loss_zero;
    return @PREFIX@_SUCCESS;
  }
  if (heap->fix_loss_one_multiple) {
    *out_head = heap->fix_loss_one_multiple;
    return @PREFIX@_SUCCESS;
  }
  if (heap->fix_loss_one_single) {
    *out_head = heap->fix_loss_one_single;
    return @PREFIX@_SUCCESS;
  }
  if (heap->fix_loss_two) {
    *out_head = heap->fix_loss_two;
    return @PREFIX@_SUCCESS;
  }

  *out_head = NULL;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insertion_point.
 * \param heap Internal parameter.
 * \param group Internal parameter.
 * \param out_node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insertion_point(@PREFIX@_heap_t *heap,
                                                  int group,
                                                  @PREFIX@_node_t **out_node) {
  @PREFIX@_node_t *points[SFH_NUM_FIX_GROUPS];
  int i;

  if (!heap || !out_node)
    return @PREFIX@_ERR_NULL_ARG;

  points[0] = heap->fix_passive;
  points[1] = heap->fix_free_multiple;
  points[2] = heap->fix_free_single;
  points[3] = heap->fix_loss_zero;
  points[4] = heap->fix_loss_one_multiple;
  points[5] = heap->fix_loss_one_single;
  points[6] = heap->fix_loss_two;

  for (i = 0; i < SFH_NUM_FIX_GROUPS; ++i) {
    int idx = (group + i) % SFH_NUM_FIX_GROUPS;
    if (points[idx]) {
      *out_node = points[idx];
      return @PREFIX@_SUCCESS;
    }
  }

  *out_node = NULL;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_insert.
 * \param heap Internal parameter.
 * \param group Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_insert(@PREFIX@_heap_t *heap, int group,
                                         @PREFIX@_node_t *node) {
  @PREFIX@_node_t *succ;

  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;

  SFH_CHECK_RC(fix_list_insertion_point(heap, group, &succ));

  SFH_CHECK_RC(fix_list_insert_before(node, succ));

  if (group == FREE_MULTIPLE_GROUP)
    heap->fix_free_multiple = node;
  else if (group == FREE_SINGLE_GROUP)
    heap->fix_free_single = node;
  else if (group == LOSS_ZERO_GROUP)
    heap->fix_loss_zero = node;
  else if (group == LOSS_ONE_MULTIPLE_GROUP)
    heap->fix_loss_one_multiple = node;
  else if (group == LOSS_ONE_SINGLE_GROUP)
    heap->fix_loss_one_single = node;
  else if (group == LOSS_TWO_GROUP)
    heap->fix_loss_two = node;

  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_group.
 * \param node Internal parameter.
 * \param head Internal parameter.
 * \param count Internal parameter.
 * \param first Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_group(@PREFIX@_node_t *node,
                                        @PREFIX@_node_t *head, int *count,
                                        @PREFIX@_node_t **first) {
  @PREFIX@_node_t *last;
  int same;

  if (!node || !count || !first)
    return @PREFIX@_ERR_NULL_ARG;

  last = node;
  *count = 1;
  *first = node;

  while (*count < SFH_GROUP_MAX_COUNT && *first != head) {
    SFH_CHECK_RC(fix_list_same_group(node, (*first)->prev, &same));
    if (!same)
      break;
    *first = (*first)->prev;
    (*count)++;
  }

  while (*count < SFH_GROUP_MAX_COUNT && last->next != head) {
    SFH_CHECK_RC(fix_list_same_group(node, last->next, &same));
    if (!same)
      break;
    last = last->next;
    (*count)++;
  }

  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_retire.
 * \param heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t fix_list_retire(@PREFIX@_heap_t *heap) {
  if (!heap)
    return @PREFIX@_ERR_NULL_ARG;
  heap->fix_passive = NULL;
  heap->fix_free_multiple = NULL;
  heap->fix_free_single = NULL;
  heap->fix_loss_zero = NULL;
  heap->fix_loss_one_multiple = NULL;
  heap->fix_loss_one_single = NULL;
  heap->fix_loss_two = NULL;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_add.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */

static @PREFIX@_error_t fix_list_add_free(@PREFIX@_heap_t *heap,
                                           @PREFIX@_node_t *node,
                                           @PREFIX@_node_t *head) {
  @PREFIX@_node_t *first = node->rank->free_node;
  if (first == NULL) {
    node->rank->free_node = node;
    SFH_CHECK_RC(fix_list_insert(heap, FREE_SINGLE_GROUP, node));
  } else {
    int count;
    @PREFIX@_node_t *f;
    SFH_CHECK_RC(fix_list_group(first, head, &count, &f));

    if (count >= 2) {
      SFH_CHECK_RC(fix_list_insert_after(node, first));
    } else {
      if (heap->fix_free_single == first) {
        int next_is_free = 0;
        if (first->next != head) {
          SFH_CHECK_RC(node_is_free(first->next, &next_is_free));
        }
        if (next_is_free) {
          heap->fix_free_single = first->next;
        } else {
          heap->fix_free_single = NULL;
        }
      }
      SFH_CHECK_RC(fix_list_unlink(first));
      SFH_CHECK_RC(fix_list_insert(heap, FREE_MULTIPLE_GROUP, node));
      SFH_CHECK_RC(fix_list_insert(heap, FREE_MULTIPLE_GROUP, first));
      node->rank->free_node = first;
    }
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add_fixed_loss_zero(@PREFIX@_heap_t *heap,
                                                      @PREFIX@_node_t *node) {
  SFH_CHECK_RC(fix_list_insert(heap, LOSS_ZERO_GROUP, node));
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add_fixed_loss_two(@PREFIX@_heap_t *heap,
                                                     @PREFIX@_node_t *node) {
  SFH_CHECK_RC(fix_list_insert(heap, LOSS_TWO_GROUP, node));
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add_fixed_loss_one(@PREFIX@_heap_t *heap,
                                                     @PREFIX@_node_t *node,
                                                     @PREFIX@_node_t *head) {
  @PREFIX@_node_t *first = node->rank->loss_one_node;
  if (first == NULL) {
    node->rank->loss_one_node = node;
    SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_SINGLE_GROUP, node));
  } else {
    int count;
    @PREFIX@_node_t *f;
    SFH_CHECK_RC(fix_list_group(first, head, &count, &f));

    if (count >= 2) {
      SFH_CHECK_RC(fix_list_insert_after(node, first));
    } else {
      if (heap->fix_loss_one_single == first) {
        int next_is_fixed = 0;
        if (first->next != head) {
          SFH_CHECK_RC(node_is_fixed(first->next, &next_is_fixed));
        }
        if (next_is_fixed && first->next->loss == 1) {
          heap->fix_loss_one_single = first->next;
        } else {

          heap->fix_loss_one_single = NULL;
        }
      }
      SFH_CHECK_RC(fix_list_unlink(first));
      SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_MULTIPLE_GROUP, node));
      SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_MULTIPLE_GROUP, first));
    }
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_add(@PREFIX@_heap_t *heap,
                                      @PREFIX@_node_t *node) {
  @PREFIX@_node_t *head;
  int is_free;

  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;

  SFH_CHECK_RC(fix_list_head(heap, &head));

  SFH_CHECK_RC(node_is_free(node, &is_free));

  if (is_free) {
    SFH_CHECK_RC(fix_list_add_free(heap, node, head));
  } else {
    if (node->loss == 0) {
      SFH_CHECK_RC(fix_list_add_fixed_loss_zero(heap, node));
    } else if (node->loss >= 2) {
      SFH_CHECK_RC(fix_list_add_fixed_loss_two(heap, node));
    } else {
      SFH_CHECK_RC(fix_list_add_fixed_loss_one(heap, node, head));
    }
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function fix_list_remove.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */

static @PREFIX@_error_t fix_list_remove_passive(@PREFIX@_heap_t *heap,
                                                 @PREFIX@_node_t *node,
                                                 @PREFIX@_node_t *head,
                                                 @PREFIX@_node_t *succ) {
  if (heap->fix_passive == node) {
    int succ_is_passive = 0;
    if (succ != head) {
      SFH_CHECK_RC(node_is_passive(succ, &succ_is_passive));
    }
    if (succ_is_passive)
      heap->fix_passive = succ;
    else
      heap->fix_passive = NULL;
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_free(@PREFIX@_heap_t *heap,
                                              @PREFIX@_node_t *node,
                                              @PREFIX@_node_t *head,
                                              @PREFIX@_node_t *succ) {
  int count;
  @PREFIX@_node_t *first;
  SFH_CHECK_RC(fix_list_group(node, head, &count, &first));
  if (count == 1) {
    if (heap->fix_free_single == node) {
      int succ_is_free = 0;
      if (succ != head) {
        SFH_CHECK_RC(node_is_free(succ, &succ_is_free));
      }
      if (succ_is_free)
        heap->fix_free_single = succ;
      else
        heap->fix_free_single = NULL;
    }
  } else if (count >= SFH_GROUP_MAX_COUNT) {
    if (heap->fix_free_multiple == node)
      heap->fix_free_multiple = succ;
  } else {
    @PREFIX@_node_t *other = (first != node) ? first : succ;
    if (heap->fix_free_multiple == first) {
      int f_free = 0, fn_free = 0;
      first = first->next->next;
      if (first != head) {
        SFH_CHECK_RC(node_is_free(first, &f_free));
      }
      if (first->next != head) {
        SFH_CHECK_RC(node_is_free(first->next, &fn_free));
      }
      if (f_free && fn_free && first->rank == first->next->rank) {
        heap->fix_free_multiple = first;
      } else {
        heap->fix_free_multiple = NULL;
      }
    }
    SFH_CHECK_RC(fix_list_unlink(other));
    SFH_CHECK_RC(fix_list_insert(heap, FREE_SINGLE_GROUP, other));
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_loss_zero(@PREFIX@_heap_t *heap,
                                                   @PREFIX@_node_t *node,
                                                   @PREFIX@_node_t *head,
                                                   @PREFIX@_node_t *succ) {
  if (heap->fix_loss_zero == node) {
    int succ_is_fixed = 0;
    if (succ != head) {
      SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed));
    }
    if (succ_is_fixed && succ->loss == 0)
      heap->fix_loss_zero = succ;
    else
      heap->fix_loss_zero = NULL;
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_loss_two(@PREFIX@_heap_t *heap,
                                                  @PREFIX@_node_t *node,
                                                  @PREFIX@_node_t *head,
                                                  @PREFIX@_node_t *succ) {
  if (heap->fix_loss_two == node) {
    int succ_is_fixed = 0;
    if (succ != head) {
      SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed));
    }
    if (succ_is_fixed && succ->loss >= 2)
      heap->fix_loss_two = succ;
    else
      heap->fix_loss_two = NULL;
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove_loss_one(@PREFIX@_heap_t *heap,
                                                  @PREFIX@_node_t *node,
                                                  @PREFIX@_node_t *head,
                                                  @PREFIX@_node_t *succ) {
  int count;
  @PREFIX@_node_t *first;
  SFH_CHECK_RC(fix_list_group(node, head, &count, &first));
  if (count == 1) {
    if (heap->fix_loss_one_single == node) {
      int succ_is_fixed = 0;
      if (succ != head) {
        SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed));
      }
      if (succ_is_fixed && succ->loss == 1)
        heap->fix_loss_one_single = succ;
      else
        heap->fix_loss_one_single = NULL;
    }
  } else if (count >= SFH_GROUP_MAX_COUNT) {
    if (heap->fix_loss_one_multiple == node)
      heap->fix_loss_one_multiple = succ;
  } else {
    @PREFIX@_node_t *other = (first != node) ? first : succ;
    if (heap->fix_loss_one_multiple == first) {
      int f_fixed = 0, fn_fixed = 0;
      first = first->next->next;
      if (first != head) {
        SFH_CHECK_RC(node_is_fixed(first, &f_fixed));
      }
      if (first->next != head) {
        SFH_CHECK_RC(node_is_fixed(first->next, &fn_fixed));
      }
      if (f_fixed && first->loss == 1 && fn_fixed && first->next->loss == 1 &&
          first->rank == first->next->rank) {
        heap->fix_loss_one_multiple = first;
      } else {
        heap->fix_loss_one_multiple = NULL;
      }
    }
    SFH_CHECK_RC(fix_list_unlink(other));
    SFH_CHECK_RC(fix_list_insert(heap, LOSS_ONE_SINGLE_GROUP, other));
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t fix_list_remove(@PREFIX@_heap_t *heap,
                                         @PREFIX@_node_t *node) {
  @PREFIX@_node_t *succ;
  @PREFIX@_node_t *head;
  int is_active, is_passive, is_free;

  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;

  succ = node->next;
  SFH_CHECK_RC(fix_list_head(heap, &head));
  SFH_CHECK_RC(node_is_active(node, &is_active));

  if (is_active && node->rank->free_node == node) {
    int succ_is_free = 0;
    if (succ != head) {
      SFH_CHECK_RC(node_is_free(succ, &succ_is_free));
    }
    if (succ_is_free && succ->rank == node->rank) {
      node->rank->free_node = succ;
    } else {
      node->rank->free_node = NULL;
    }
  }

  if (is_active && node->rank->loss_one_node == node) {
    int succ_is_fixed = 0;
    if (succ != head) {
      SFH_CHECK_RC(node_is_fixed(succ, &succ_is_fixed));
    }
    if (succ_is_fixed && succ->loss == 1 && succ->rank == node->rank) {
      node->rank->loss_one_node = succ;
    } else {
      node->rank->loss_one_node = NULL;
    }
  }

  if (heap->size == 1) {
    SFH_CHECK_RC(fix_list_retire(heap));
  } else {
    SFH_CHECK_RC(node_is_passive(node, &is_passive));
    SFH_CHECK_RC(node_is_free(node, &is_free));

    if (is_passive) {
      SFH_CHECK_RC(fix_list_remove_passive(heap, node, head, succ));
    } else if (is_free) {
      SFH_CHECK_RC(fix_list_remove_free(heap, node, head, succ));
    } else {
      if (node->loss == 0) {
        SFH_CHECK_RC(fix_list_remove_loss_zero(heap, node, head, succ));
      } else if (node->loss >= 2) {
        SFH_CHECK_RC(fix_list_remove_loss_two(heap, node, head, succ));
      } else {
        SFH_CHECK_RC(fix_list_remove_loss_one(heap, node, head, succ));
      }
    }
    SFH_CHECK_RC(fix_list_unlink(node));
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function get_rank_obj.
 * \param heap Internal parameter.
 * \param r Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t get_rank_obj(@PREFIX@_heap_t *heap, int r,
                                      @PREFIX@_rank_t **out_rank) {
  @PREFIX@_rank_t *rank;
  if (r >= SFH_MAX_RANKS) {

    return @PREFIX@_ERR_OUT_OF_RANKS;
  }
  rank = &heap->rank_pool[r];
  if (rank->heap == NULL) {
    rank->heap = heap;
    rank->rank = r;
    rank->free_node = NULL;
    rank->loss_one_node = NULL;
    rank->reference_count = 0;
    rank->next = NULL;
    rank->prev = NULL;
  }
  *out_rank = rank;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_decrease_reference_count.
 * \param rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_decrease_reference_count(@PREFIX@_rank_t *rank) {
  @PREFIX@_heap_t *heap;
  if (!rank)
    return @PREFIX@_ERR_NULL_ARG;
  heap = rank->heap;
  rank->reference_count--;
  if (rank->reference_count == 0) {
    if (heap->rank_list == rank) {
      heap->rank_list = rank->next;
    }
    if (rank->next)
      rank->next->prev = rank->prev;
    if (rank->prev)
      rank->prev->next = rank->next;
    rank->next = NULL;
    rank->prev = NULL;
    rank->heap = NULL;
    rank->free_node = NULL;
    rank->loss_one_node = NULL;
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_increase_reference_count.
 * \param rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_increase_reference_count(@PREFIX@_rank_t *rank) {
  if (!rank)
    return @PREFIX@_ERR_NULL_ARG;
  rank->reference_count++;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_next.
 * \param rank Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_next(@PREFIX@_rank_t *rank,
                                   @PREFIX@_rank_t **out_rank) {
  if (rank->next == NULL || rank->next->rank > rank->rank + 1) {
    @PREFIX@_rank_t *new_rank;
    SFH_CHECK_RC(get_rank_obj(rank->heap, rank->rank + 1, &new_rank));
    new_rank->prev = rank;
    new_rank->next = rank->next;
    rank->next = new_rank;
    if (new_rank->next)
      new_rank->next->prev = new_rank;
  }
  *out_rank = rank->next;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function rank_prev.
 * \param rank Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t rank_prev(@PREFIX@_rank_t *rank,
                                   @PREFIX@_rank_t **out_rank) {
  if (rank->prev == NULL || rank->prev->rank < rank->rank - 1) {

    @PREFIX@_rank_t *new_rank;
    SFH_CHECK_RC(get_rank_obj(rank->heap, rank->rank - 1, &new_rank));
    new_rank->prev = rank->prev;
    new_rank->next = rank;
    if (new_rank->prev)
      new_rank->prev->next = new_rank;
    else
      rank->heap->rank_list = new_rank;
    rank->prev = new_rank;
  }
  *out_rank = rank->prev;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_rank_zero.
 * \param heap Internal parameter.
 * \param out_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_rank_zero(@PREFIX@_heap_t *heap,
                                        @PREFIX@_rank_t **out_rank) {
  @PREFIX@_rank_t *rank;
  if (!heap || !out_rank)
    return @PREFIX@_ERR_NULL_ARG;
  rank = heap->rank_list;
  if (rank == NULL) {
    SFH_CHECK_RC(get_rank_obj(heap, 0, &rank));
    heap->rank_list = rank;
  }
  SFH_CHECK_RC(rank_increase_reference_count(rank));
  *out_rank = rank;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_change_rank.
 * \param node Internal parameter.
 * \param new_rank Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_adjust_loss(@PREFIX@_heap_t *heap,
                                          @PREFIX@_node_t *node, int delta) {
  SFH_CHECK_RC(fix_list_remove(heap, node));
  node->loss += delta;
  SFH_CHECK_RC(fix_list_add(heap, node));
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t node_change_rank(@PREFIX@_node_t *node,
                                          @PREFIX@_rank_t *new_rank) {
  @PREFIX@_heap_t *heap;
  SFH_CHECK_RC(node_heap(node, &heap));
  SFH_CHECK_RC(rank_increase_reference_count(new_rank));
  SFH_CHECK_RC(fix_list_remove(heap, node));
  SFH_CHECK_RC(rank_decrease_reference_count(node->rank));
  node->rank = new_rank;
  SFH_CHECK_RC(fix_list_add(heap, node));
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_increase_rank.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_increase_rank(@PREFIX@_node_t *node) {
  @PREFIX@_rank_t *next_rank;
  SFH_CHECK_RC(rank_next(node->rank, &next_rank));
  return node_change_rank(node, next_rank);
}

/**
 * \brief Internal function node_decrease_rank.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_decrease_rank(@PREFIX@_node_t *node) {
  @PREFIX@_rank_t *prev_rank;
  SFH_CHECK_RC(rank_prev(node->rank, &prev_rank));
  return node_change_rank(node, prev_rank);
}

/**
 * \brief Internal function node_add_child.
 * \param parent Internal parameter.
 * \param child Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_add_child(@PREFIX@_node_t *parent,
                                        @PREFIX@_node_t *child) {
  int child_is_passive, parent_is_active, child_is_fixed;

  child->parent = parent;
  if (parent->left_child == NULL) {
    parent->left_child = child;
  } else {
    child->right = parent->left_child;
    child->left = child->right->left;
    child->right->left = child;
    child->left->right = child;

    SFH_CHECK_RC(node_is_passive(child, &child_is_passive));
    if (!child_is_passive) {
      parent->left_child = child;
    }
  }

  SFH_CHECK_RC(node_is_active(parent, &parent_is_active));
  SFH_CHECK_RC(node_is_fixed(child, &child_is_fixed));
  if (parent_is_active && child_is_fixed) {
    SFH_CHECK_RC(node_increase_rank(parent));
  }
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t node_unlink_from_parent(@PREFIX@_node_t *node) {
  @PREFIX@_node_t *parent = node->parent;
  @PREFIX@_node_t *right = node->right;
  @PREFIX@_node_t *left = node->left;

  node->parent = NULL;
  if (parent != NULL && parent->left_child == node) {
    if (right != node)
      parent->left_child = right;
    else
      parent->left_child = NULL;
  }

  if (right != node) {
    left->right = right;
    right->left = left;
    node->right = node;
    node->left = node;
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_cut.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_cut(@PREFIX@_heap_t *heap,
                                  @PREFIX@_node_t *node) {
  @PREFIX@_node_t *parent = node->parent;
  int node_fixed, parent_active, parent_fixed;

  SFH_CHECK_RC(node_unlink_from_parent(node));

  SFH_CHECK_RC(node_is_fixed(node, &node_fixed));
  SFH_CHECK_RC(node_is_active(parent, &parent_active));

  if (node_fixed && parent_active) {
    SFH_CHECK_RC(node_decrease_rank(parent));

    SFH_CHECK_RC(node_is_fixed(parent, &parent_fixed));
    if (parent_fixed) {
      SFH_CHECK_RC(node_adjust_loss(heap, parent, 1));
    }
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_free2fixed.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_set_state(@PREFIX@_heap_t *heap,
                                        @PREFIX@_node_t *node, int is_free,
                                        int loss) {
  SFH_CHECK_RC(fix_list_remove(heap, node));
  node->is_free = is_free;
  node->loss = loss;
  SFH_CHECK_RC(fix_list_add(heap, node));
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t node_free2fixed(@PREFIX@_node_t *node) {
  @PREFIX@_heap_t *heap;
  SFH_CHECK_RC(node_heap(node, &heap));
  SFH_CHECK_RC(node_set_state(heap, node, 0, 0));
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_fixed2free.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_fixed2free(@PREFIX@_node_t *node) {
  @PREFIX@_node_t *parent = node->parent;
  @PREFIX@_heap_t *heap;
  int parent_fixed;

  SFH_CHECK_RC(node_heap(node, &heap));
  SFH_CHECK_RC(node_set_state(heap, node, 1, -1));

  SFH_CHECK_RC(node_decrease_rank(parent));

  SFH_CHECK_RC(node_is_fixed(parent, &parent_fixed));
  if (parent_fixed) {
    SFH_CHECK_RC(node_adjust_loss(heap, parent, 1));
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_passive2free.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_passive2free(@PREFIX@_heap_t *heap,
                                           @PREFIX@_node_t *node) {
  @PREFIX@_rank_t *rank_zero;
  @PREFIX@_node_t *parent = node->parent;

  SFH_CHECK_RC(heap_rank_zero(heap, &rank_zero));

  SFH_CHECK_RC(fix_list_remove(heap, node));
  SFH_CHECK_RC(rank_decrease_reference_count(node->rank));
  node->rank = rank_zero;
  node->is_free = 1;
  node->loss = -1;

  if (parent != NULL) {
    SFH_CHECK_RC(node_cut(heap, node));
    SFH_CHECK_RC(node_add_child(parent, node));
  }
  SFH_CHECK_RC(fix_list_add(heap, node));
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_link.
 * \param heap Internal parameter.
 * \param x Internal parameter.
 * \param y Internal parameter.
 * \param out_winner Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_link(@PREFIX@_heap_t *heap, @PREFIX@_node_t *x,
                                   @PREFIX@_node_t *y,
                                   @PREFIX@_node_t **out_winner) {
  int is_lt;
  (void)heap;
  SFH_CHECK_RC(node_lt(x, y, &is_lt));
  if (is_lt) {
    SFH_CHECK_RC(node_add_child(x, y));
    *out_winner = x;
  } else {
    SFH_CHECK_RC(node_add_child(y, x));
    *out_winner = y;
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_passive.
 * \param heap Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_passive(@PREFIX@_heap_t *heap) {
  int i;
  for (i = 0; i < SFH_PASSIVE_REDUCTIONS; ++i) {
    if (heap->fix_passive == NULL)
      return @PREFIX@_SUCCESS;
    SFH_CHECK_RC(node_passive2free(heap, heap->fix_passive));
  }
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_free.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_free(@PREFIX@_heap_t *heap,
                                          int *out_changed) {
  @PREFIX@_node_t *x = heap->fix_free_multiple;
  @PREFIX@_node_t *y, *z;
  int is_lt, z_passive;
  *out_changed = 0;
  if (x == NULL)
    return @PREFIX@_SUCCESS;
  y = x->next;

  SFH_CHECK_RC(node_lt(y, x, &is_lt));
  if (is_lt) {
    @PREFIX@_node_t *tmp = x;
    x = y;
    y = tmp;
  }

  SFH_CHECK_RC(node_cut(heap, y));

  SFH_CHECK_RC(node_free2fixed(y));

  SFH_CHECK_RC(node_add_child(x, y));

  z = x->left_child->left;
  SFH_CHECK_RC(node_is_passive(z, &z_passive));
  if (z_passive) {

    SFH_CHECK_RC(node_cut(heap, z));
    SFH_CHECK_RC(node_add_child(heap->root, z));
  }
  *out_changed = 1;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_root.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */

static @PREFIX@_error_t heap_reduce_root_cut_and_sort(@PREFIX@_heap_t *heap,
                                                       @PREFIX@_node_t **x_ptr,
                                                       @PREFIX@_node_t **y_ptr,
                                                       @PREFIX@_node_t **z_ptr) {
  @PREFIX@_node_t *x = *x_ptr, *y = *y_ptr, *z = *z_ptr, *tmp;
  int lt;
  SFH_CHECK_RC(node_cut(heap, x));
  SFH_CHECK_RC(node_cut(heap, y));
  SFH_CHECK_RC(node_cut(heap, z));

  SFH_CHECK_RC(node_passive2free(heap, x));
  SFH_CHECK_RC(node_passive2free(heap, y));
  SFH_CHECK_RC(node_passive2free(heap, z));

  SFH_CHECK_RC(node_lt(y, x, &lt));
  if (lt) {
    tmp = x;
    x = y;
    y = tmp;
  }

  SFH_CHECK_RC(node_lt(z, y, &lt));
  if (lt) {

    tmp = y;
    y = z;
    z = tmp;
    SFH_CHECK_RC(node_lt(y, x, &lt));
    if (lt) {
      tmp = x;
      x = y;
      y = tmp;
    }
  }

  *x_ptr = x;
  *y_ptr = y;
  *z_ptr = z;
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t heap_reduce_root(@PREFIX@_heap_t *heap,
                                          int *out_changed) {
  @PREFIX@_node_t *root = heap->root;
  @PREFIX@_node_t *x, *y, *z;
  int x_passive;
  *out_changed = 0;

  if (root == NULL || root->left_child == NULL)
    return @PREFIX@_SUCCESS;

  z = root->left_child->left;
  y = z->left;
  x = y->left;

  SFH_CHECK_RC(node_is_passive(x, &x_passive));
  if (z == y || z == x || !x_passive)
    return @PREFIX@_SUCCESS;

  SFH_CHECK_RC(heap_reduce_root_cut_and_sort(heap, &x, &y, &z));

  SFH_CHECK_RC(node_free2fixed(y));
  SFH_CHECK_RC(node_free2fixed(z));

  SFH_CHECK_RC(node_add_child(root, x));
  SFH_CHECK_RC(node_add_child(x, y));
  SFH_CHECK_RC(node_add_child(y, z));

  *out_changed = 1;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_loss_one.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_loss_one(@PREFIX@_heap_t *heap,
                                              int *out_changed) {
  @PREFIX@_node_t *x = heap->fix_loss_one_multiple;
  @PREFIX@_node_t *y, *z;
  int is_lt, z_passive;
  *out_changed = 0;
  if (x == NULL)
    return @PREFIX@_SUCCESS;
  y = x->next;

  SFH_CHECK_RC(node_lt(y, x, &is_lt));
  if (is_lt) {
    @PREFIX@_node_t *tmp = x;
    x = y;
    y = tmp;
  }

  SFH_CHECK_RC(node_cut(heap, y));

  SFH_CHECK_RC(node_adjust_loss(heap, x, -1));
  SFH_CHECK_RC(node_adjust_loss(heap, y, -1));

  SFH_CHECK_RC(node_add_child(x, y));

  z = x->left_child->left;
  SFH_CHECK_RC(node_is_passive(z, &z_passive));
  if (z_passive) {

    SFH_CHECK_RC(node_cut(heap, z));
    SFH_CHECK_RC(node_add_child(heap->root, z));
  }
  *out_changed = 1;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_loss_two.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_loss_two(@PREFIX@_heap_t *heap,
                                              int *out_changed) {
  @PREFIX@_node_t *x = heap->fix_loss_two;
  *out_changed = 0;
  if (x == NULL)
    return @PREFIX@_SUCCESS;
  SFH_CHECK_RC(node_fixed2free(x));
  *out_changed = 1;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function heap_reduce_loss.
 * \param heap Internal parameter.
 * \param out_changed Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_reduce_loss(@PREFIX@_heap_t *heap,
                                          int *out_changed) {
  *out_changed = 0;
  SFH_CHECK_RC(heap_reduce_loss_one(heap, out_changed));
  if (*out_changed)
    return @PREFIX@_SUCCESS;

  SFH_CHECK_RC(heap_reduce_loss_two(heap, out_changed));

  return @PREFIX@_SUCCESS;
}

typedef @PREFIX@_error_t (*reduction_func)(@PREFIX@_heap_t *, int *);

/**
 * \brief Internal function heap_apply_reductions.
 * \param heap Internal parameter.
 * \param reductions Internal parameter.
 * \param count Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t heap_apply_reductions(@PREFIX@_heap_t *heap,
                                               reduction_func *reductions,
                                               int count) {
  reduction_func failed[SFH_MAX_REDUCTIONS];
  int failed_count;
  int i;
  int changed;

  if (count > SFH_MAX_REDUCTIONS)
    count = SFH_MAX_REDUCTIONS;

  while (count > 0) {
    failed_count = 0;
    for (i = 0; i < count; ++i) {
      SFH_CHECK_RC(reductions[i](heap, &changed));
      if (!changed) {
        failed[failed_count++] = reductions[i];
      }
    }
    if (failed_count == count)
      return @PREFIX@_SUCCESS;
    for (i = 0; i < failed_count; ++i) {
      reductions[i] = failed[i];
    }
    count = failed_count;
  }

  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_init(@PREFIX@_heap_t *heap) {
  int i;
  if (!heap)
    return @PREFIX@_ERR_NULL_ARG;

  heap->active = 1;
  heap->size = 0;
  heap->root = NULL;
  heap->rank_list = NULL;

  heap->fix_passive = NULL;
  heap->fix_free_multiple = NULL;
  heap->fix_free_single = NULL;
  heap->fix_loss_zero = NULL;
  heap->fix_loss_one_multiple = NULL;
  heap->fix_loss_one_single = NULL;
  heap->fix_loss_two = NULL;

  for (i = 0; i < SFH_MAX_RANKS; ++i) {
    heap->rank_pool[i].heap = NULL;
  }

  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_empty(const @PREFIX@_heap_t *heap, int *out_empty) {
  if (!heap || !out_empty)
    return @PREFIX@_ERR_NULL_ARG;
  *out_empty = (heap->size == 0) ? 1 : 0;
  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_find_min(const @PREFIX@_heap_t *heap, @PREFIX@_node_t **out_node) {
  if (!heap || !out_node)
    return @PREFIX@_ERR_NULL_ARG;
  if (heap->size == 0)
    return @PREFIX@_ERR_EMPTY;
  *out_node = heap->root;
  return @PREFIX@_SUCCESS;
}

/**
 * \brief Internal function node_retire.
 * \param heap Internal parameter.
 * \param node Internal parameter.
 * \return Internal return value.
 */
static @PREFIX@_error_t node_retire(@PREFIX@_heap_t *heap,
                                     @PREFIX@_node_t *node) {
  @PREFIX@_rank_t *rank;
  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;
  rank = node->rank;
  SFH_CHECK_RC(fix_list_remove(heap, node));
  heap->size--;
  node->rank = NULL;
  SFH_CHECK_RC(rank_decrease_reference_count(rank));
  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_insert(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node,
             @PREFIX@_key_t key, @PREFIX@_val_t value) {
  reduction_func reductions[SFH_INSERT_REDUCTIONS];
  @PREFIX@_rank_t *rank_zero;

  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;

  SFH_CHECK_RC(heap_rank_zero(heap, &rank_zero));

  heap->size++;
  node->key = key;
  node->value = value;
  node->parent = NULL;
  node->left_child = NULL;
  node->right = node;
  node->left = node;
  node->is_free = 1;
  node->loss = -1;
  node->is_min_inf = 0;

  node->rank = rank_zero;
  node->prev = node;
  node->next = node;
  SFH_CHECK_RC(fix_list_add(heap, node));

  if (heap->root == NULL) {
    heap->root = node;
  } else {
    @PREFIX@_node_t *new_root;
    SFH_CHECK_RC(heap_link(heap, heap->root, node, &new_root));
    heap->root = new_root;

    reductions[0] = heap_reduce_free;
    reductions[1] = heap_reduce_free;
    reductions[2] = heap_reduce_free;
    reductions[3] = heap_reduce_root;
    reductions[4] = heap_reduce_root;
    SFH_CHECK_RC(
        heap_apply_reductions(heap, reductions, SFH_INSERT_REDUCTIONS));
  }

  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_meld(@PREFIX@_heap_t *h1, @PREFIX@_heap_t *h2,
                                 @PREFIX@_heap_t **out_heap) {
  @PREFIX@_heap_t *small_heap, *large_heap;
  reduction_func reductions[SFH_MELD_REDUCTIONS];

  if (!h1 || !h2 || !out_heap)
    return @PREFIX@_ERR_NULL_ARG;

  if (h1->size < h2->size) {

    small_heap = h1;
    large_heap = h2;

  } else {
    small_heap = h2;
    large_heap = h1;
  }

  small_heap->active = 0;
  large_heap->size += small_heap->size;

  if (small_heap->size > 0) {
    @PREFIX@_node_t *small_root = small_heap->root;
    @PREFIX@_node_t *large_head;
    @PREFIX@_node_t *small_head;
    @PREFIX@_node_t *new_root;

    small_heap->size = 0;
    small_heap->root = NULL;
    small_heap->rank_list = NULL;
    SFH_CHECK_RC(fix_list_retire(small_heap));

    SFH_CHECK_RC(fix_list_head(large_heap, &large_head));
    small_head = small_root;

    SFH_CHECK_RC(fix_list_splice(small_head, large_head));

    large_heap->fix_passive = small_head;

    SFH_CHECK_RC(
        heap_link(large_heap, large_heap->root, small_root, &new_root));
    large_heap->root = new_root;

    reductions[0] = heap_reduce_free;
    reductions[1] = heap_reduce_root;
    SFH_CHECK_RC(
        heap_apply_reductions(large_heap, reductions, SFH_MELD_REDUCTIONS));
  }

  *out_heap = large_heap;
  return @PREFIX@_SUCCESS;
}

static @PREFIX@_error_t heap_consolidate_roots(@PREFIX@_heap_t *heap,
                                                @PREFIX@_node_t *root) {
  @PREFIX@_node_t *new_root = root->left_child;
  @PREFIX@_node_t *child = new_root->right;
  int child_fixed, is_lt;

  while (child != root->left_child) {
    SFH_CHECK_RC(node_lt(child, new_root, &is_lt));
    if (is_lt) {
      new_root = child;
    }
    child = child->right;
  }

  SFH_CHECK_RC(node_is_fixed(new_root, &child_fixed));
  if (child_fixed) {
    SFH_CHECK_RC(node_fixed2free(new_root));
  }
  SFH_CHECK_RC(node_cut(heap, new_root));

  while (root->left_child != NULL) {
    @PREFIX@_node_t *winner;
    child = root->left_child;
    SFH_CHECK_RC(node_is_fixed(child, &child_fixed));
    if (child_fixed) {
      SFH_CHECK_RC(node_fixed2free(child));
    }
    SFH_CHECK_RC(node_cut(heap, child));
    SFH_CHECK_RC(heap_link(heap, new_root, child, &winner));
  }

  heap->root = new_root;
  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_delete_min(@PREFIX@_heap_t *heap) {
  @PREFIX@_node_t *root;

  if (!heap)
    return @PREFIX@_ERR_NULL_ARG;
  if (heap->size == 0)
    return @PREFIX@_ERR_EMPTY;

  root = heap->root;
  if (heap->size == 1) {
    heap->root = NULL;
    SFH_CHECK_RC(node_retire(heap, root));
  } else {
    SFH_CHECK_RC(heap_consolidate_roots(heap, root));

    SFH_CHECK_RC(node_retire(heap, root));
    SFH_CHECK_RC(heap_reduce_passive(heap));

    while (1) {
      int changed;
      SFH_CHECK_RC(heap_reduce_loss(heap, &changed));
      if (!changed)
        break;
    }

    while (1) {
      int changed1, changed2;
      SFH_CHECK_RC(heap_reduce_free(heap, &changed1));

      SFH_CHECK_RC(heap_reduce_root(heap, &changed2));

      if (!changed1 && !changed2)
        break;
    }
  }
  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_decrease_key(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node,
                   @PREFIX@_key_t key) {
  @PREFIX@_node_t *parent;
  @PREFIX@_node_t *new_root;
  reduction_func reductions[SFH_DECREASE_KEY_REDUCTIONS];
  int i;
  int changed;
  int is_lt = 0, node_fixed;

  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;

  node->key = key;
  parent = node->parent;

  if (parent != NULL) {
    SFH_CHECK_RC(node_lt(node, parent, &is_lt));
  }

  if (parent == NULL || !is_lt) {
    return @PREFIX@_SUCCESS;
  }

  SFH_CHECK_RC(node_is_fixed(node, &node_fixed));
  if (node_fixed) {
    SFH_CHECK_RC(node_fixed2free(node));
  }

  SFH_CHECK_RC(node_cut(heap, node));

  SFH_CHECK_RC(heap_link(heap, node, heap->root, &new_root));
  heap->root = new_root;

  SFH_CHECK_RC(heap_reduce_loss(heap, &changed));

  for (i = 0; i < 6; ++i)
    reductions[i] = heap_reduce_free;
  for (i = 6; i < SFH_DECREASE_KEY_REDUCTIONS; ++i)
    reductions[i] = heap_reduce_root;

  SFH_CHECK_RC(
      heap_apply_reductions(heap, reductions, SFH_DECREASE_KEY_REDUCTIONS));

  return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_delete(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
  if (!heap || !node)
    return @PREFIX@_ERR_NULL_ARG;

  node->is_min_inf = 1;
  SFH_CHECK_RC(@PREFIX@_decrease_key(heap, node, node->key));

  return @PREFIX@_delete_min(heap);
}
