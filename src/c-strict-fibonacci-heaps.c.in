            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (!changed) break; /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        }

        while (1) {
            int changed1, changed2;
            rc = heap_reduce_free(heap, &changed1); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

            rc = heap_reduce_root(heap, &changed2); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
            if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

            if (!changed1 && !changed2) break; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        }
    }
    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_decrease_key(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node, @PREFIX@_key_t key) {
    @PREFIX@_error_t rc;
    @PREFIX@_node_t *parent;
    @PREFIX@_node_t *new_root;
    reduction_func reductions[10];
    int i;
    int changed;
    int is_lt = 0, node_fixed;

    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG;

    node->key = key;
    parent = node->parent;

    if (parent != NULL) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rc = node_lt(node, parent, &is_lt); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    if (parent == NULL || !is_lt) { /* LCOV_EXCL_BR_LINE */ /* LCOV_EXCL_LINE */
        return @PREFIX@_SUCCESS;
    }
 /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    rc = node_is_fixed(node, &node_fixed); if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (node_fixed) { /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        rc = node_fixed2free(node); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
        if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    }

    rc = node_cut(heap, node); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    rc = heap_link(heap, node, heap->root, &new_root); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    heap->root = new_root;

    rc = heap_reduce_loss(heap, &changed); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    for (i = 0; i < 6; ++i) reductions[i] = heap_reduce_free;
    for (i = 6; i < 10; ++i) reductions[i] = heap_reduce_root;

    rc = heap_apply_reductions(heap, reductions, 10); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_SUCCESS;
}

@PREFIX@_error_t @PREFIX@_delete(@PREFIX@_heap_t *heap, @PREFIX@_node_t *node) {
    @PREFIX@_error_t rc;
    if (!heap || !node) return @PREFIX@_ERR_NULL_ARG;

    node->is_min_inf = 1;
    rc = @PREFIX@_decrease_key(heap, node, node->key); /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */
    if (rc != @PREFIX@_SUCCESS) return rc; /* LCOV_EXCL_LINE */ /* LCOV_EXCL_BR_LINE */

    return @PREFIX@_delete_min(heap);
}
